              }
            ]
          }
        }
      ],
      "dataConnectYaml": {
        "specVersion": "v1",
        "serviceId": "korealotto",
        "location": "us-east4",
        "schema": {
          "source": "./schema",
          "datasource": {
            "postgresql": {
              "database": "fdcdb",
              "cloudSql": {
                "instanceId": "korealotto-fdc"
              }
            }
          }
        },
        "connectorDirs": [
          "./example"
        ]
      },
      "connectorInfo": [
        {
          "directory": "C:\\Korea_Lotto\\dataconnect\\example",
          "connectorYaml": {
            "connectorId": "korealotto-connector",
            "generate": {
              "javascriptSdk": {
                "outputDir": "../../src/lib/dataconnect",
                "package": "@lotto/dataconnect",
                "packageJsonDir": "../../"
              }
            }
          },
          "connector": {
            "name": "projects/korea-lotto-db-6505/locations/us-east4/services/korealotto/connectors/korealotto-connector",
            "source": {
              "files": [
                {
                  "path": "queries.gql",
                  "content": "# List all lotto rounds, sorted by draw number descending\nquery ListLottoRounds @auth(level: PUBLIC) {\n  lottoRounds(orderBy: [{ drwNo: DESC }]) {\n    drwNo\n    drwNoDate\n    totSellamnt\n    firstWinamnt\n    firstPrzwnerCo\n    drwtNo1\n    drwtNo2\n    drwtNo3\n    drwtNo4\n    drwtNo5\n    drwtNo6\n    bnusNo\n    returnValue\n    createdAt\n  }\n}\n\n# Get a specific lotto round by its draw number\nquery GetLottoRoundByNo($drwNo: Int!) @auth(level: PUBLIC) {\n  lottoRound(key: { drwNo: $drwNo }) {\n    drwNo\n    drwNoDate\n    totSellamnt\n    firstWinamnt\n    firstPrzwnerCo\n    drwtNo1\n    drwtNo2\n    drwtNo3\n    drwtNo4\n    drwtNo5\n    drwtNo6\n    bnusNo\n    returnValue\n    createdAt\n  }\n}\n\n# Get the latest lotto round (highest drwNo)\nquery GetLatestLottoRound @auth(level: PUBLIC) {\n  lottoRounds(orderBy: [{ drwNo: DESC }], limit: 1) {\n    drwNo\n    drwNoDate\n    totSellamnt\n    firstWinamnt\n    firstPrzwnerCo\n    drwtNo1\n    drwtNo2\n    drwtNo3\n    drwtNo4\n    drwtNo5\n    drwtNo6\n    bnusNo\n    returnValue\n    createdAt\n  }\n}\n"
                },
                {
                  "path": "mutations.gql",
                  "content": "# Insert or update a LottoRound entry\nmutation UpsertLottoRound(\n  $drwNo: Int!\n  $drwNoDate: String!\n  $totSellamnt: Int!\n  $firstWinamnt: Int!\n  $firstPrzwnerCo: Int!\n  $drwtNo1: Int!\n  $drwtNo2: Int!\n  $drwtNo3: Int!\n  $drwtNo4: Int!\n  $drwtNo5: Int!\n  $drwtNo6: Int!\n  $bnusNo: Int!\n  $returnValue: String!\n) @auth(level: PUBLIC) {\n  lottoRound_upsert(\n    data: {\n      drwNo: $drwNo\n      drwNoDate: $drwNoDate\n      totSellamnt: $totSellamnt\n      firstWinamnt: $firstWinamnt\n      firstPrzwnerCo: $firstPrzwnerCo\n      drwtNo1: $drwtNo1\n      drwtNo2: $drwtNo2\n      drwtNo3: $drwtNo3\n      drwtNo4: $drwtNo4\n      drwtNo5: $drwtNo5\n      drwtNo6: $drwtNo6\n      bnusNo: $bnusNo\n      returnValue: $returnValue\n    }\n  )\n}\n"
                }
              ]
            }
          }
        }
      ],
